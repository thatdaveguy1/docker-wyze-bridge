#!/bin/sh

if [ -f /app/.env ]; then
    set -a
    # shellcheck disable=SC1091
    . /app/.env
    set +a
fi

if [ "$BUILD" = "dev" ]; then
    printenv
    cat /data/options.json
fi

if command -v whep_proxy >/dev/null 2>&1; then
    whep_proxy &
fi

. /app/go2rtc_sidecar.sh
start_go2rtc_sidecar

exec flask run --host=0.0.0.0 --port=5000
